# Hetzner Storage Box (SMB/CIFS) credentials
# Copy to .env and fill in your values
STORAGEBOX_HOST=//uXXXXX.your-storagebox.de
STORAGEBOX_SHARE=backup
STORAGEBOX_USER=uXXXXX
STORAGEBOX_PASS=your_password_here

# umut Quickwit S3 configuration
# Optional: configure via /etc/umut/umut.toml [s3] section instead
# UMUT_S3_ENDPOINT=https://s3.amazonaws.com
# UMUT_S3_REGION=us-east-1
# UMUT_S3_BUCKET=umut-quickwit
# UMUT_S3_ACCESS_KEY_ID=
# UMUT_S3_SECRET_ACCESS_KEY=
